# Clé API Last.fm (pour sources/Artistes_Similaires)
LASTFM_API_KEY=your_lastfm_api_key_here

# Credentials Spotify (pour sources/Playlists_Spotify)
# Créer une app sur https://developer.spotify.com/dashboard → "Create app"
# Redirect URI requis : http://localhost (peu importe, Client Credentials n'en a pas besoin)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Chemin vers la bibliothèque musicale locale (accessible depuis WSL)
# Windows M:\musiques\__Autres → /mnt/m/musiques/__Autres dans WSL
LIBRARY_PATH=/mnt/m/musiques/__Autres
